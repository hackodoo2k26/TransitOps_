<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="user_fleet_manager" model="res.users">
            <field name="name">Fleet Manager</field>
            <field name="login">manager@transitops.com</field>
            <field name="role">fleet_manager</field>
            <field name="password">password123</field>
            <field name="groups_id" eval="[(4, ref('transitops_auth.group_fleet_manager')), (4, ref('base.group_user'))]"/>
        </record>

        <record id="user_driver" model="res.users">
            <field name="name">Driver User</field>
            <field name="login">driver@transitops.com</field>
            <field name="role">driver</field>
            <field name="password">password123</field>
            <field name="groups_id" eval="[(4, ref('transitops_auth.group_driver')), (4, ref('base.group_user'))]"/>
        </record>

        <record id="user_safety_officer" model="res.users">
            <field name="name">Safety Officer</field>
            <field name="login">safety@transitops.com</field>
            <field name="role">safety_officer</field>
            <field name="password">password123</field>
            <field name="groups_id" eval="[(4, ref('transitops_auth.group_safety_officer')), (4, ref('base.group_user'))]"/>
        </record>

        <record id="user_financial_analyst" model="res.users">
            <field name="name">Financial Analyst</field>
            <field name="login">analyst@transitops.com</field>
            <field name="role">financial_analyst</field>
            <field name="password">password123</field>
            <field name="groups_id" eval="[(4, ref('transitops_auth.group_financial_analyst')), (4, ref('base.group_user'))]"/>
        </record>

        <!-- Demo Vehicles -->
        <record id="vehicle_van_05" model="transitops.vehicle">
            <field name="registration_number">VAN-05</field>
            <field name="model_name">Ford Transit 350</field>
            <field name="type">van</field>
            <field name="max_load_capacity">500</field>
            <field name="odometer">45230</field>
            <field name="acquisition_cost">35000</field>
            <field name="region">North</field>
            <field name="status">available</field>
        </record>

        <record id="vehicle_truck_12" model="transitops.vehicle">
            <field name="registration_number">TRK-12</field>
            <field name="model_name">Volvo FH16</field>
            <field name="type">truck</field>
            <field name="max_load_capacity">12000</field>
            <field name="odometer">128500</field>
            <field name="acquisition_cost">150000</field>
            <field name="region">South</field>
            <field name="status">on_trip</field>
        </record>

        <record id="vehicle_bus_08" model="transitops.vehicle">
            <field name="registration_number">BUS-08</field>
            <field name="model_name">Mercedes Sprinter</field>
            <field name="type">bus</field>
            <field name="max_load_capacity">2000</field>
            <field name="odometer">89200</field>
            <field name="acquisition_cost">65000</field>
            <field name="region">East</field>
            <field name="status">in_shop</field>
        </record>

        <record id="vehicle_van_03" model="transitops.vehicle">
            <field name="registration_number">VAN-03</field>
            <field name="model_name">RAM ProMaster</field>
            <field name="type">van</field>
            <field name="max_load_capacity">600</field>
            <field name="odometer">31500</field>
            <field name="acquisition_cost">42000</field>
            <field name="region">West</field>
            <field name="status">retired</field>
        </record>

        <record id="vehicle_truck_07" model="transitops.vehicle">
            <field name="registration_number">TRK-07</field>
            <field name="model_name">Scania R500</field>
            <field name="type">truck</field>
            <field name="max_load_capacity">15000</field>
            <field name="odometer">67200</field>
            <field name="acquisition_cost">175000</field>
            <field name="region">North</field>
            <field name="status">available</field>
        </record>

