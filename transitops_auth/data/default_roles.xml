        <record id="driver_alex" model="transitops.driver">
            <field name="name">Alex Johnson</field>
            <field name="license_number">LIC-12345</field>
            <field name="license_category">Class C</field>
            <field name="license_expiry_date">2027-06-15</field>
            <field name="contact_number">+1-555-0101</field>
            <field name="safety_score">95</field>
            <field name="status">available</field>
        </record>

        <record id="driver_sarah" model="transitops.driver">
            <field name="name">Sarah Chen</field>
            <field name="license_number">LIC-12346</field>
            <field name="license_category">Class A</field>
            <field name="license_expiry_date">2026-03-22</field>
            <field name="contact_number">+1-555-0102</field>
            <field name="safety_score">88</field>
