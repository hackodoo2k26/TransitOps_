            <field name="liters">240</field>
            <field name="cost">420</field>
            <field name="date">2026-07-09</field>
        </record>

        <!-- Demo Expenses -->
        <record id="exp_001" model="transitops.expense">
            <field name="vehicle_id" ref="vehicle_truck_12"/>
