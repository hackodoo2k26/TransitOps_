        <!-- Demo Trips -->
        <record id="trip_001" model="transitops.trip">
            <field name="source">Warehouse A - North</field>
            <field name="destination">Distribution Center 3</field>
            <field name="vehicle_id" ref="vehicle_truck_12"/>
            <field name="driver_id" ref="driver_sarah"/>
            <field name="cargo_weight">8500</field>
            <field name="planned_distance">340</field>
            <field name="start_odometer">128500</field>
            <field name="status">dispatched</field>
        </record>

        <record id="trip_002" model="transitops.trip">
            <field name="source">Depot Main</field>
            <field name="destination">Retail Hub 7</field>
            <field name="vehicle_id" ref="vehicle_van_05"/>
            <field name="driver_id" ref="driver_alex"/>
            <field name="cargo_weight">320</field>
            <field name="planned_distance">85</field>
            <field name="start_odometer">45230</field>
            <field name="end_odometer">45350</field>
            <field name="fuel_consumed">18.5</field>
            <field name="revenue">1200</field>
            <field name="status">completed</field>
        </record>

        <record id="trip_003" model="transitops.trip">
            <field name="source">Port Terminal</field>
            <field name="destination">City Depot</field>
            <field name="vehicle_id" ref="vehicle_van_05"/>
            <field name="driver_id" ref="driver_alex"/>
            <field name="cargo_weight">150</field>
            <field name="planned_distance">45</field>
            <field name="status">draft</field>
        </record>

        <!-- Demo Maintenance Logs -->
        <record id="maint_001" model="transitops.maintenance_log">
            <field name="vehicle_id" ref="vehicle_bus_08"/>
            <field name="description">Oil change and brake pad replacement</field>
            <field name="cost">450</field>
            <field name="date">2026-07-08</field>
            <field name="status">active</field>
        </record>

        <record id="maint_002" model="transitops.maintenance_log">
            <field name="vehicle_id" ref="vehicle_van_05"/>
            <field name="description">Tire rotation and alignment</field>
            <field name="cost">200</field>
            <field name="date">2026-06-20</field>
            <field name="status">closed</field>
        </record>

        <record id="maint_003" model="transitops.maintenance_log">
            <field name="vehicle_id" ref="vehicle_truck_07"/>
            <field name="description">Annual safety inspection</field>
            <field name="cost">350</field>
            <field name="date">2026-07-01</field>
            <field name="status">closed</field>
        </record>

        <!-- Demo Fuel Logs -->
        <record id="fuel_001" model="transitops.fuel_log">
            <field name="vehicle_id" ref="vehicle_truck_12"/>
            <field name="liters">180</field>
            <field name="cost">315</field>
            <field name="date">2026-07-11</field>
        </record>

        <record id="fuel_002" model="transitops.fuel_log">
            <field name="vehicle_id" ref="vehicle_van_05"/>
