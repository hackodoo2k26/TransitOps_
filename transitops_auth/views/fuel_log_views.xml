<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_fuel_log_tree" model="ir.ui.view">
            <field name="name">transitops.fuel_log.tree</field>
            <field name="model">transitops.fuel_log</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="vehicle_id"/>
                    <field name="trip_id"/>
                    <field name="liters"/>
                    <field name="cost"/>
                    <field name="date"/>
                </tree>
            </field>
        </record>

        <record id="view_fuel_log_form" model="ir.ui.view">
            <field name="name">transitops.fuel_log.form</field>
            <field name="model">transitops.fuel_log</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="vehicle_id"/>
                                <field name="trip_id"/>
                            </group>
                            <group>
                                <field name="liters"/>
                                <field name="cost"/>
                                <field name="date"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_transitops_fuel_log" model="ir.actions.act_window">
            <field name="name">Fuel Logs</field>
            <field name="res_model">transitops.fuel_log</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem
            id="menu_transitops_fuel_logs"
            name="Fuel Logs"
            parent="transitops_auth.menu_transitops_root"
            action="action_transitops_fuel_log"
            sequence="60"/>
    </data>
</odoo>
