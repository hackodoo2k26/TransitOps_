<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_trip_tree" model="ir.ui.view">
            <field name="name">transitops.trip.tree</field>
            <field name="model">transitops.trip</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="source"/>
                    <field name="destination"/>
                    <field name="vehicle_id"/>
                    <field name="driver_id"/>
                    <field name="cargo_weight"/>
                    <field name="status"/>
                </tree>
            </field>
        </record>

        <record id="view_trip_form" model="ir.ui.view">
            <field name="name">transitops.trip.form</field>
            <field name="model">transitops.trip</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_dispatch" string="Dispatch" type="object" states="draft" class="btn-primary"/>
                        <button name="action_complete" string="Complete" type="object" states="dispatched" class="btn-success"/>
                        <button name="action_cancel" string="Cancel" type="object" states="draft,dispatched" class="btn-danger"/>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="source"/>
                                <field name="destination"/>
                                <field name="vehicle_id"/>
                                <field name="driver_id"/>
                            </group>
                            <group>
                                <field name="cargo_weight"/>
                                <field name="planned_distance"/>
                                <field name="start_odometer"/>
                                <field name="end_odometer"/>
                                <field name="fuel_consumed"/>
                                <field name="revenue"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_trip_search" model="ir.ui.view">
            <field name="name">transitops.trip.search</field>
            <field name="model">transitops.trip</field>
            <field name="arch" type="xml">
                <search>
                    <field name="source"/>
                    <field name="destination"/>
                    <field name="vehicle_id"/>
                    <field name="driver_id"/>
                    <filter name="status_draft" string="Draft" domain="[('status','=','draft')]"/>
                    <filter name="status_dispatched" string="Dispatched" domain="[('status','=','dispatched')]"/>
                    <filter name="status_completed" string="Completed" domain="[('status','=','completed')]"/>
                </search>
            </field>
        </record>

        <record id="action_transitops_trip" model="ir.actions.act_window">
            <field name="name">Trips</field>
            <field name="res_model">transitops.trip</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_trip_search"/>
        </record>

        <menuitem
            id="menu_transitops_trips"
            name="Trips"
            parent="transitops_auth.menu_transitops_root"
            action="action_transitops_trip"
            sequence="40"/>
    </data>
</odoo>
