<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_users_tree_transitops" model="ir.ui.view">
            <field name="name">res.users.tree.transitops</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_tree"/>
            <field name="arch" type="xml">
                <field name="login" position="after">
                    <field name="role"/>
                </field>
            </field>
        </record>

        <record id="view_users_form_transitops" model="ir.ui.view">
            <field name="name">res.users.form.transitops</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='login']" position="after">
                    <field name="role" widget="selection"/>
                </xpath>
            </field>
        </record>

        <record id="action_open_transitops_users" model="ir.actions.act_window">
            <field name="name">TransitOps Users</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('role', '!=', False)]</field>
        </record>

        <menuitem id="menu_transitops_root" name="TransitOps" sequence="10"/>
        <menuitem id="menu_transitops_config" name="Configuration" parent="menu_transitops_root" sequence="10"/>
        <menuitem
            id="menu_transitops_users"
            name="Users"
            parent="menu_transitops_config"
            action="action_open_transitops_users"
            groups="transitops_auth.group_fleet_manager"
            sequence="10"/>
    </data>
</odoo>
