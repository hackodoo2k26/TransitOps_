<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_maintenance_tree" model="ir.ui.view">
            <field name="name">transitops.maintenance_log.tree</field>
            <field name="model">transitops.maintenance_log</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="vehicle_id"/>
                    <field name="description"/>
                    <field name="cost"/>
                    <field name="date"/>
                    <field name="status"/>
                </tree>
            </field>
        </record>

        <record id="view_maintenance_form" model="ir.ui.view">
            <field name="name">transitops.maintenance_log.form</field>
            <field name="model">transitops.maintenance_log</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_close" string="Close" type="object" states="active" class="btn-success"/>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="vehicle_id"/>
                                <field name="description"/>
                            </group>
                            <group>
                                <field name="cost"/>
                                <field name="date"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_transitops_maintenance" model="ir.actions.act_window">
            <field name="name">Maintenance</field>
            <field name="res_model">transitops.maintenance_log</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem
            id="menu_transitops_maintenance"
            name="Maintenance"
            parent="transitops_auth.menu_transitops_root"
            action="action_transitops_maintenance"
            sequence="50"/>
    </data>
</odoo>
