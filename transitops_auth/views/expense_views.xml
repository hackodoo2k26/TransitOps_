<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_expense_tree" model="ir.ui.view">
            <field name="name">transitops.expense.tree</field>
            <field name="model">transitops.expense</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="vehicle_id"/>
                    <field name="type"/>
                    <field name="amount"/>
                    <field name="date"/>
                </tree>
            </field>
        </record>

        <record id="view_expense_form" model="ir.ui.view">
            <field name="name">transitops.expense.form</field>
            <field name="model">transitops.expense</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="vehicle_id"/>
                                <field name="type"/>
                            </group>
                            <group>
                                <field name="amount"/>
                                <field name="date"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_transitops_expense" model="ir.actions.act_window">
            <field name="name">Expenses</field>
            <field name="res_model">transitops.expense</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem
            id="menu_transitops_expenses"
            name="Expenses"
            parent="transitops_auth.menu_transitops_root"
            action="action_transitops_expense"
            sequence="70"/>
    </data>
</odoo>
