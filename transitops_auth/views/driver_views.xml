<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_driver_tree" model="ir.ui.view">
            <field name="name">transitops.driver.tree</field>
            <field name="model">transitops.driver</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="license_number"/>
                    <field name="license_category"/>
                    <field name="license_expiry_date"/>
                    <field name="contact_number"/>
                    <field name="safety_score"/>
                    <field name="status"/>
                </tree>
            </field>
        </record>

        <record id="view_driver_form" model="ir.ui.view">
            <field name="name">transitops.driver.form</field>
            <field name="model">transitops.driver</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="license_number"/>
                                <field name="license_category"/>
                                <field name="license_expiry_date"/>
                            </group>
                            <group>
                                <field name="contact_number"/>
                                <field name="safety_score"/>
                                <field name="status"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="trips" string="Trips">
                                <field name="trip_ids">
                                    <tree>
                                        <field name="source"/>
                                        <field name="destination"/>
                                        <field name="vehicle_id"/>
                                        <field name="status"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_driver_search" model="ir.ui.view">
            <field name="name">transitops.driver.search</field>
            <field name="model">transitops.driver</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="license_number"/>
                    <filter name="status_available" string="Available" domain="[('status','=','available')]"/>
                    <filter name="status_on_trip" string="On Trip" domain="[('status','=','on_trip')]"/>
                </search>
            </field>
        </record>

        <record id="action_transitops_driver" model="ir.actions.act_window">
            <field name="name">Drivers</field>
            <field name="res_model">transitops.driver</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_driver_search"/>
        </record>

        <menuitem
            id="menu_transitops_drivers"
            name="Drivers"
            parent="transitops_auth.menu_transitops_root"
            action="action_transitops_driver"
            sequence="30"/>
    </data>
</odoo>
